<!--千叶珠宝 首页-->
<view class="cu-bar search bg-white fixed" style="box-shadow:none">
  <view class="search-form">
    <text class="cuIcon-search"></text>
    <navigator class="response" hover-class='none' url='/pages/base/search/index'>
      <input type="text" placeholder="搜索千叶珠宝"></input>
    </navigator>
  </view>
</view>

<view class="margin-top-bar bg-white">

  <!-- 轮播图 -->
  <swiper class="screen-swiper square-dot" indicator-dots="true" circular="true" autoplay="true" interval="5000" duration="500" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#c8a96e">
    <swiper-item wx:for="{{swiperData}}" wx:key="index" class="margin-top-sm">
      <image class="swiper-image" src="{{item}}" mode="aspectFill"></image>
    </swiper-item>
  </swiper>

  <!-- 品牌理念 -->
  <view class="brand-slogan flex align-center justify-center padding-sm">
    <text class="text-black text-sm" style="letter-spacing:4rpx;">来我心里 · 以珠宝传递情感</text>
  </view>

  <!-- 快捷分类导航 -->
  <view class="cu-list grid no-border justify-around padding-tb-sm">
    <navigator class="cu-item" hover-class="none" url='/pages/goods/goods-list/index?categoryFirst=cat_01&title=钻石'>
      <image class="nav-image" src="/public/img/6-1.png"></image>
      <text class="text-black text-sm">钻石</text>
    </navigator>
    <navigator class="cu-item" hover-class="none" url='/pages/goods/goods-list/index?categoryFirst=cat_02&title=黄金'>
      <image class="nav-image" src="/public/img/6-2.png"></image>
      <text class="text-black text-sm">黄金</text>
    </navigator>
    <navigator class="cu-item" hover-class="none" url='/pages/goods/goods-list/index?categoryFirst=cat_03&title=珍珠'>
      <image class="nav-image" src="/public/img/6-3.png"></image>
      <text class="text-black text-sm">珍珠</text>
    </navigator>
    <navigator class="cu-item" hover-class="none" url='/pages/goods/goods-list/index?categoryFirst=cat_04&title=18K金'>
      <image class="nav-image" src="/public/img/6-4.png"></image>
      <text class="text-black text-sm">18K金</text>
    </navigator>
    <navigator class="cu-item" hover-class="none" url='/pages/goods/goods-list/index?categoryFirst=cat_05&title=情侣对戒'>
      <image class="nav-image" src="/public/img/6-5.png"></image>
      <text class="text-black text-sm">情侣对戒</text>
    </navigator>
  </view>

  <!-- 公告 -->
  <view class="adsec light bg-white margin-top-sm">
    <swiper class="swiper_container" autoplay="true" circular="true" interval="6000">
      <swiper-item>
        <view class="bg-white padding-left-sm text-black">
          <text class="cu-tag line-black text-bold">品牌</text>
          <text class="details margin-left">千叶珠宝，用心传递情感，悦己悦心</text>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="bg-white padding-left-sm text-black">
          <text class="cu-tag line-black text-bold">承诺</text>
          <text class="details margin-left">正品保证 · 30天无忧退换 · 全国联保</text>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="bg-white padding-left-sm text-black">
          <text class="cu-tag line-black text-bold">服务</text>
          <text class="details margin-left">免费刻字 · 专属礼盒 · 闪速发货</text>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 热销单品 -->
  <view class='wrapper bg-white margin-top-sm'>
    <view class="cu-bar text-black">
      <view class='action margin-left-sm'>
        <text class="text-xxl text-bold">热销单品</text>
      </view>
      <navigator hover-class="none" url='/pages/goods/goods-list/index?type=2' class='action'>
        更多<text class='cuIcon-right'></text>
      </navigator>
    </view>
    <view class='wrapper-list bg-white radius'>
      <scroll-view class="scroll-view_x hot-goods" scroll-x>
        <block wx:for="{{goodsListHot}}" wx:key="index">
          <navigator hover-class="none" url='/pages/goods/goods-detail/index?id={{item.id}}' class='item'>
            <view class='text-cut text-bold text-xxl text-black margin-top-sm'>{{item.name}}</view>
            <view class='text-cut text-sm text-gray margin-top-sm'>{{item.sellPoint}}</view>
            <view class='img-box margin-top-xl'>
              <image src="{{item.picUrls[0] ? item.picUrls[0] : '/public/img/no_pic.png'}}"></image>
            </view>
            <view class="flex justify-between margin-top">
              <view class="text-df padding-top-sm"><text class="text-price">{{item.salesPrice}}</text> 起</view>
              <view class="cu-btn round shadow-blur text-white buy-now">购买</view>
            </view>
          </navigator>
        </block>
      </scroll-view>
    </view>
  </view>

  <!-- 猜你喜欢 -->
  <view class="cu-bar margin-top-sm">
    <view class='action'>
      <text class="text-xxl text-bold text-black">为你推荐</text>
    </view>
  </view>
  <goods-card goodsList="{{goodsList}}"/>
  <view class="cu-load bg-white {{loadmore?'loading':'over'}}"></view>

</view>
